          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum(rate(tienda_request_duration_seconds_bucket[2m])) by (le, endpoint))",
          "legendFormat": "p99 {{endpoint}}",
          "range": true,
          "refId": "B"
        }
